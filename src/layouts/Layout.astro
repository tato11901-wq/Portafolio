---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Portafolio Interactivo" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-p5-black text-p5-white min-h-screen overflow-x-clip">
		<main class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 py-12 md:py-20 overflow-x-clip">
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		--color-p5-red: #E50012;
		--color-p5-black: #0F0F0F;
		--color-p5-white: #F4F4F4;
	}
	
	body {
		background-image: radial-gradient(rgba(244, 244, 244, 0.15) 1px, transparent 1px);
		background-size: 16px 16px;
	}
</style>
