---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/p5/NavBar.astro";
import { ProjectViews } from "../components/p5/ProjectViews";
import type { ProjectData } from "../types";
import proyectos from "../data/proyectos.json";

const toFlatProject = (p: ProjectData) => ({
  title: p.title,
  description: p.description.es,
  tags: p.tags,
  featured: p.featured,
  mediaUrl: p.media?.[0]?.url,
  media: p.media ?? [],
  role: p.role?.es,
  primaryButton: p.primaryButton
    ? { text: p.primaryButton.text.es, href: p.primaryButton.href }
    : undefined,
  secondaryButton: p.secondaryButton
    ? { text: p.secondaryButton.text.es, href: p.secondaryButton.href }
    : undefined,
});

const proyectosTyped = proyectos as ProjectData[];
const devProjects = proyectosTyped.filter((p) => p.category === "dev").map(toFlatProject);
const artProjects = proyectosTyped.filter((p) => p.category === "art").map(toFlatProject);
---

<Layout title="Proyectos - Alejandro Sandoval">
  <!-- Navigation Bar -->
  <NavBar currentPath="/proyectos" />

  <div class="space-y-32 pb-40 px-2 md:px-6 w-full max-w-none mx-auto">
    <section class="flex flex-col gap-12 mt-16 relative">
      <h1 class="font-display text-5xl md:text-7xl bg-p5-black text-p5-white inline-block px-8 py-4 -skew-x-[6deg] shadow-hard-white self-center mb-8 transition-colors" id="project-title-heading">
        <span class="inline-block skew-x-[6deg]">ALL PROJECTS</span>
      </h1>

      <ProjectViews 
        client:load 
        devProjects={devProjects} 
        artProjects={artProjects} 
      />
    </section>
  </div>
</Layout>
