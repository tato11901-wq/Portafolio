---
import Layout from "../layouts/Layout.astro";
import { CallingCard } from "../components/p5/CallingCard";
import NavBar from "../components/p5/NavBar.astro";
import { P5Button } from "../components/p5/P5Button";

type LocalizedText = {
  es: string;
  en: string;
};

type TimelineItem = {
  year: string;
  title: LocalizedText;
  description: LocalizedText;
  inverted?: boolean;
};

const timelineItems: TimelineItem[] = [
  {
    year: "2022",
    title: {
      es: "Inicio de carrera",
      en: "Starting my degree",
    },
    description: {
      es: "Comencé Ingeniería Multimedia y consolidé mis bases en programación, lógica, matemáticas y fundamentos técnicos que hoy sostienen mi proceso creativo.",
      en: "I began my Multimedia Engineering degree and built strong foundations in programming, logic, mathematics, and technical thinking that still support my creative process today.",
    },
  },
  {
    year: "2023",
    title: {
      es: "Primer contacto con Unity",
      en: "First contact with Unity",
    },
    description: {
      es: "Descubrí Unity y C# a través de prototipos tempranos. Aunque esos primeros experimentos fueron caóticos, me ayudaron a entender el motor, iterar más rápido y perderle el miedo a construir sistemas.",
      en: "I discovered Unity and C# through early prototypes. Those first experiments were messy, but they taught me how the engine works, how to iterate faster, and how to become comfortable building systems.",
    },
    inverted: true,
  },
  {
    year: "2024",
    title: {
      es: "Modelado 3D y pipeline visual",
      en: "3D modeling and visual pipeline",
    },
    description: {
      es: "Empecé a trabajar con modelado 3D en Maya, Mudbox y Substance, aprendiendo desde bloqueos con primitivas hasta modelos listos para texturizado, rigging y animación dentro de un pipeline de producción.",
      en: "I started working with 3D modeling in Maya, Mudbox and Substance, learning everything from primitive blockouts to production-ready models prepared for texturing, rigging, and animation.",
    },
  },
  {
    year: "2024",
    title: {
      es: "Diseño de interfaces interactivas",
      en: "Interactive interface design",
    },
    description: {
      es: "Profundicé en UI/UX para experiencias digitales, explorando wireframes, prototipos y decisiones visuales que conectaran la funcionalidad con una identidad clara.",
      en: "I went deeper into UI/UX for digital experiences, exploring wireframes, prototypes, and visual decisions that connect usability with a strong identity.",
    },
    inverted: true,
  },
  {
    year: "2025",
    title: {
      es: "Primeros proyectos integrales",
      en: "First end-to-end projects",
    },
    description: {
      es: "Comencé a unir programación, arte y diseño en proyectos más completos, trabajando sistemas jugables, presentación visual y una intención narrativa más clara dentro de cada prototipo.",
      en: "I started combining programming, art, and design in more complete projects, building playable systems, visual presentation, and clearer narrative intent into each prototype.",
    },
  },
  {
    year: "2026",
    title: {
      es: "Desarrollo de videojuegos en Unity",
      en: "Video game development in Unity",
    },
    description: {
      es: "Teniendo claros los conocimientos necesarios para desarrollar aplicaciones más complejas, tuve la oportunidad de aventurarme en el desarrollo de videojuegos con Unity, aplicando mis conocimientos en programación, arte y diseño, mientras servía a su vez como tech leader de varios proyectos en Unity.",
      en: "With solid knowledge in programming, art and design, I had the opportunity to venture into video game development with Unity, applying my knowledge in programming, art and design as tech leader of several projects in Unity",
    },
    inverted: true,
  },
  {
    year: "2026",
    title: {
      es: "Aplicaciones Web y frameworks",
      en: "Web applications and frameworks",
    },
    description: {
      es: "Desarrollé aplicaciones web utilizando tecnologías modernas más allá de un clasico HTML/CSS, aprovechando el potencial de herramientas como Astro y Tailwind CSS para desarrollar aplicativos web interactivos de mayor complejidad",
      en: "I developed web applications using modern technologies beyond a classic HTML/CSS, taking advantage of the potential of tools like Astro and Tailwind CSS to develop interactive web applications of greater complexity",
    },
  },

  {
    year: "2026",
    title: {
      es: "Búsqueda de mi primer rol profesional",
      en: "Search for my first professional role",
    },
    inverted: true,
    description: {
      es: "Ahora, finalizando mi carrera, me encuentro en búsqueda de mi primer rol profesional como desarrollador de videojuegos, gameplay programmer o desarrollador de experiencias interactivas, donde pueda aportar mis conocimientos en programación, arte y diseño.",
      en: "Now, finishing my degree, I am looking for my first professional role as a game developer, gameplay programmer, or interactive experience developer, where I can contribute my knowledge in programming, art and design.",
    },
  },
];

const hobbyCards = [
  {
    emoji: "RPG",
    variant: "dark",
    title: {
      es: "RPGS E INDIES",
      en: "RPGS & INDIES",
    },
    description: {
      es: "Analizo sistemas por turnos, progresión y narrativa ramificada.",
      en: "I study turn-based systems, progression loops, and branching narrative.",
    },
  },
  {
    emoji: "UI",
    variant: "light",
    title: {
      es: "DISEÑO DE INTERFACES",
      en: "INTERFACE DESIGN",
    },
    description: {
      es: "Me interesan la UI diegética y los estilos visuales con mucha identidad.",
      en: "I am drawn to diegetic UI and visual styles with strong identity.",
    },
  },
  {
    emoji: "3D",
    variant: "dark-red",
    title: {
      es: "ANIMACIÓN",
      en: "ANIMATION",
    },
    description: {
      es: "Disfruto estudiar actuación, timing y dirección de arte en 2D y 3D.",
      en: "I enjoy studying acting, timing, and art direction in both 2D and 3D.",
    },
  },
  {
    emoji: "OST",
    variant: "red",
    title: {
      es: "SOUNDTRACKS",
      en: "SOUNDTRACKS",
    },
    description: {
      es: "Escucho jazz, rock y música de videojuegos como combustible creativo.",
      en: "I listen to jazz, rock, and game soundtracks as creative fuel.",
    },
  },
];

const academicEvents = [
  {
    year: "2026",
    title: {
      es: "Encuentro Nacional REDCOLSI",
      en: "REDCOLSI National Congress",
    },
    role: {
      es: "Ponente • Red Colombiana de Semilleros de Investigación",
      en: "Speaker • Colombian Network of Research Seedbeds",
    },
    description: {
      es: "Presentación del sistema de combate para la adaptación a videojuego de Sveliaty, un RPG por turnos con elementos roguelike donde las decisiones del jugador repercuten en el aspecto final del personaje.",
      en: "Presentation of the combat system for the video game adaptation of Sveliaty, a turn-based RPG with roguelike elements where player decisions impact the character's final appearance.",
    },
    link: "#",
    linkText: {
      es: "Ver evento",
      en: "View event"
    }
  },
  {
    year: "2025",
    title: {
      es: "Encuentro Universitario CEIMA",
      en: "CEIMA University Forum",
    },
    role: {
      es: "Ponente • Institución Universitaria Compensar",
      en: "Speaker • Institución Universitaria Compensar",
    },
    description: {
      es: "Presentación de NUX INTERACTIVE, iniciativa para englobar los productos desarrollados en JOBS, y primer vistazo público de Sveliaty como juego de mesa con tableros modulares y generación de personajes basada en el desempeño del jugador.",
      en: "Presentation of NUX INTERACTIVE, an initiative encompassing products developed at JOBS, and the first public showcase of Sveliaty as a board game featuring modular boards and performance-based character generation.",
    },
    link: null,
    linkText: {
      es: "Memorias no disponibles",
      en: "Memories not available"
    }
  },
  {
    year: "2024",
    title: {
      es: "Congreso Internacional Transdigital",
      en: "Transdigital International Congress",
    },
    role: {
      es: "Ponente Académico • Tecnologías Disruptivas y Sociedad",
      en: "Academic Speaker • Disruptive Technologies & Society",
    },
    description: {
      es: "Presentación de Twist Me, un producto modular con piezas intercambiables y papel dibujable para la creación de personajes sencillos basados en reglas específicas de diseño.",
      en: "Presentation of Twist Me, a modular product with interchangeable parts and drawable paper for creating simple characters based on specific design rules.",
    },
    link: "https://www.editorial.transdigital.mx/tecnologias-disruptivas-y-sociedad/",
    linkText: {
      es: "Ver evento",
      en: "View event"
    }
  },
];
---

<Layout title="Sobre mí - Alejandro Sandoval">
  <NavBar currentPath="/sobre-mi" />

  <div
    class="space-y-32 pb-40 px-4 md:px-8 w-full max-w-6xl mx-auto flex flex-col overflow-visible"
  >
    <div class="flex justify-center mt-8">
      <h1
        class="font-display text-5xl md:text-7xl bg-p5-red text-p5-white inline-block px-12 py-6 -skew-x-[6deg] shadow-[12px_12px_0_0_#0F0F0F] mb-8 border-4 border-p5-black"
      >
        <span class="inline-block skew-x-[6deg]">
          <span class="lang-es">ARCHIVO DE PERFIL</span>
          <span class="lang-en">PROFILE ARCHIVE</span>
        </span>
      </h1>
    </div>

    <section class="relative">
      <div
        class="absolute -top-6 -left-4 bg-p5-red text-p5-white px-6 py-2 font-display text-3xl -skew-x-[6deg] z-10 border-2 border-p5-black shadow-[4px_4px_0_0_#0F0F0F]"
      >
        <span class="inline-block skew-x-[6deg]">
          <span class="lang-es">QUIÉN SOY</span>
          <span class="lang-en">WHO AM I</span>
        </span>
      </div>
      <div
        class="bg-p5-black border-4 border-p5-red p-8 md:p-12 shadow-[12px_12px_0_0_#F4F4F4] pt-16 relative overflow-hidden"
      >
        <div
          class="absolute inset-0 bg-halftone opacity-10 pointer-events-none"
        >
        </div>

        <div
          class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 relative z-10"
        >
          <div class="flex flex-col gap-4">
            <div
              class="bg-p5-white text-p5-black px-4 py-3 border-4 border-p5-black -skew-x-[6deg] shadow-hard"
            >
              <span
                class="inline-block skew-x-[6deg] font-mono text-xs text-p5-red uppercase tracking-widest block mb-1"
              >
                <span class="lang-es">UBICACIÓN</span>
                <span class="lang-en">LOCATION</span>
              </span>
              <span
                class="inline-block skew-x-[6deg] font-display text-2xl uppercase leading-none"
              >
                Colombia
              </span>
            </div>
            <div
              class="bg-p5-white text-p5-black px-4 py-3 border-4 border-p5-black -skew-x-[6deg] shadow-hard"
            >
              <span
                class="inline-block skew-x-[6deg] font-mono text-xs text-p5-red uppercase tracking-widest block mb-1"
              >
                <span class="lang-es">PERFIL</span>
                <span class="lang-en">PROFILE</span>
              </span>
              <span
                class="inline-block skew-x-[6deg] font-display text-2xl uppercase leading-none"
              >
                Game Dev &amp; UI
              </span>
            </div>
            <div
              class="bg-p5-white text-p5-black px-4 py-3 border-4 border-p5-black -skew-x-[6deg] shadow-hard"
            >
              <span
                class="inline-block skew-x-[6deg] font-mono text-xs text-p5-red uppercase tracking-widest block mb-1"
              >
                <span class="lang-es">EXPERIENCIA</span>
                <span class="lang-en">EXPERIENCE</span>
              </span>
              <span
                class="inline-block skew-x-[6deg] font-display text-2xl uppercase leading-none"
              >
                <span class="lang-es">1+ AÑO</span>
                <span class="lang-en">1+ YEAR</span>
              </span>
            </div>
          </div>

          <div class="md:col-span-2 flex flex-col gap-6 justify-center">
            <p
              class="font-body text-lg md:text-xl text-p5-white leading-relaxed border-l-8 border-p5-red pl-6"
            >
              <span class="lang-es"
                >Soy Alejandro Sandoval, ingeniero multimedia enfocado en crear
                experiencias interactivas. Combino programación, diseño visual,
                narrativa y experiencia de usuario para construir mundos que se
                sientan vivos y memorables para quienes los recorren.</span
              >
              <span class="lang-en"
                >I am Alejandro Sandoval, a multimedia engineer focused on
                building interactive experiences. I combine programming, visual
                design, narrative, and user experience to create worlds that
                feel alive and memorable for the people who explore them.</span
              >
            </p>
            <p
              class="font-body text-base text-p5-white opacity-70 leading-relaxed border-l-4 border-p5-white/30 pl-6"
            >
              <span class="lang-es"
                >Me especializo en Unity y C#, con experiencia adicional en
                modelado 3D, diseño de interfaces y desarrollo web. Actualmente
                estoy cerrando mi etapa universitaria mientras busco mi primera
                oportunidad profesional en la industria.</span
              >
              <span class="lang-en"
                >I specialize in Unity and C#, with additional experience in 3D
                modeling, interface design, and web development. I am currently
                finishing university while looking for my first professional
                opportunity in the industry.</span
              >
            </p>
            <div class="pt-4 self-start">
              <P5Button
                href="/Assets/CV_Alejandro_Sandoval.pdf"
                variant="primary"
                download="CV_Alejandro_Sandoval.pdf"
                className="group"
              >
                <svg
                  slot="icon"
                  class="w-6 h-6 mr-1 group-hover/btn:animate-bounce"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"
                  ></path>
                </svg>
                <span class="lang-es">DESCARGAR CV / HOJA DE VIDA</span>
                <span class="lang-en">DOWNLOAD RESUME / CV</span>
              </P5Button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="relative">
      <div
        class="absolute -top-6 -left-4 bg-p5-black text-p5-white px-6 py-2 font-display text-3xl -skew-x-[6deg] z-10 border-2 border-p5-white shadow-[4px_4px_0_0_#E50012]"
      >
        <span class="inline-block skew-x-[6deg]">
          <span class="lang-es">01. FILOSOFÍA DE TRABAJO</span>
          <span class="lang-en">01. WORK PHILOSOPHY</span>
        </span>
      </div>
      <div
        class="bg-p5-white border-4 border-p5-black p-8 md:p-12 shadow-hard pt-12 relative overflow-hidden group"
      >
        <div
          class="absolute right-0 bottom-0 opacity-5 pointer-events-none transform translate-x-4 translate-y-12"
        >
          <span class="font-display text-[200px] leading-none">"</span>
        </div>
        <p
          class="font-body text-xl md:text-2xl text-p5-black font-bold leading-relaxed border-l-8 border-p5-red pl-6 relative z-10"
        >
          <span class="lang-es"
            >Trabajo desde la iteración y la escucha. Me gusta diseñar sistemas
            a partir de necesidades reales, mantener una arquitectura limpia y
            modular, y asegurar que lo visual no sea un adorno sino parte
            esencial de la experiencia. Busco que cada proyecto funcione bien,
            escale con criterio y también transmita intención, personalidad y
            cuidado.</span
          >
          <span class="lang-en"
            >I work through iteration and close listening. I like designing
            systems around real needs, keeping the architecture clean and
            modular, and making sure the visual layer is not decoration but an
            essential part of the experience. I want every project to work well,
            scale thoughtfully, and also communicate intention, personality, and
            care.</span
          >
        </p>
      </div>
    </section>

    <section class="relative flex justify-end">
      <div class="w-full md:w-[90%] relative">
        <div
          class="absolute -top-6 -right-4 bg-p5-red text-p5-white px-6 py-2 font-display text-3xl -skew-x-[6deg] z-10 border-2 border-p5-black shadow-[4px_4px_0_0_#0F0F0F]"
        >
          <span class="inline-block skew-x-[6deg]">
            <span class="lang-es">02. POR QUÉ GAMEDEV</span>
            <span class="lang-en">02. WHY GAMEDEV</span>
          </span>
        </div>
        <div
          class="bg-p5-black border-4 border-p5-red p-8 md:p-12 shadow-[12px_12px_0_0_#F4F4F4] pt-12 relative overflow-hidden group hover:border-p5-white transition-colors duration-500"
        >
          <div class="absolute inset-0 bg-halftone opacity-20"></div>
          <div
            class="absolute -left-10 top-1/2 transform -translate-y-1/2 -rotate-90 opacity-10"
          >
            <span class="font-display text-8xl tracking-widest text-p5-red"
              >PASSION</span
            >
          </div>
          <p
            class="font-body text-lg md:text-xl text-p5-white leading-relaxed relative z-10 border-r-4 border-p5-red pr-6 text-right"
          >
            <span class="lang-es"
              >Siempre me han atraído los mundos capaces de atraparte por su
              historia, sus personajes, sus mecánicas y la forma en que todo
              dialoga para decir algo. Los videojuegos, para mí, son el punto de
              encuentro perfecto entre tecnología, arte e interacción. Por eso
              quiero formar parte de equipos que busquen dejar huella a través
              de experiencias inolvidables. Adicionalmente, soy fiel creyente de
              que quienes crean videojuegos deben ser primero amantes de los
              mismos, me considero a mi mismo una persona que siente gran pasión
              por este arte.
            </span>
            <span class="lang-en"
              >I have always been drawn to worlds that pull you in through
              story, characters, mechanics, and the way every layer works
              together to say something meaningful. To me, games are the perfect
              meeting point between technology, art, and interaction. That is
              why I want to be part of teams that aim to leave a mark through
              unforgettable experiences. Additionally, I am a firm believer that
              those who create video games must first be lovers of the same, I
              consider myself a person who feels great passion for this art.
            </span>
          </p>
        </div>
      </div>
    </section>

    <section class="relative">
      <div
        class="absolute -top-6 -left-4 bg-p5-black text-p5-white px-6 py-2 font-display text-3xl -skew-x-[6deg] z-10 border-2 border-p5-white shadow-[4px_4px_0_0_#E50012]"
      >
        <span class="inline-block skew-x-[6deg]">
          <span class="lang-es">03. TIMELINE ACADÉMICA</span>
          <span class="lang-en">03. ACADEMIC TIMELINE</span>
        </span>
      </div>
      <div
        class="bg-p5-white border-4 border-p5-black p-8 md:p-12 shadow-hard pt-16"
      >
        <details class="group">
          <summary class="list-none cursor-pointer">
            <div
              class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 bg-p5-black text-p5-white border-4 border-p5-red px-6 py-5 -skew-x-[3deg] shadow-[8px_8px_0_0_#E50012] hover:-translate-y-1 transition-transform"
            >
              <div class="skew-x-[3deg]">
                <div class="font-display text-3xl uppercase leading-none">
                  <span class="lang-es">DESPLEGAR RECORRIDO</span>
                  <span class="lang-en">EXPAND JOURNEY</span>
                </div>
                <p class="font-body text-sm opacity-80 mt-2">
                  <span class="lang-es"
                    >7 hitos sobre cómo fui construyendo mi perfil.</span
                  >
                  <span class="lang-en"
                    >7 milestones that show how I built my profile.</span
                  >
                </p>
              </div>
              <div
                class="font-mono text-xs uppercase tracking-widest border-2 border-p5-white px-3 py-2 self-start md:self-auto"
              >
                <span class="lang-es">&gt; CLICK PARA ABRIR</span>
                <span class="lang-en">&gt; CLICK TO OPEN</span>
              </div>
            </div>
          </summary>

          <div
            class="mt-10 space-y-16 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-1 before:bg-p5-red"
          >
            {
              timelineItems.map((item, index) => {
                const isDark = item.inverted;
                const isRight = index % 2 === 1;
                return (
                  <div
                    class={`relative flex items-center justify-between md:justify-normal group ${
                      isRight ? "md:flex-row-reverse" : ""
                    }`}
                  >
                    <div
                      class={`flex items-center justify-center w-10 h-10 rounded-full border-4 shrink-0 z-10 group-hover:scale-125 transition-transform duration-300 ${
                        isDark
                          ? "border-p5-white bg-p5-black shadow-[2px_2px_0_0_#E50012]"
                          : "border-p5-black bg-p5-red shadow-[2px_2px_0_0_#0F0F0F]"
                      }`}
                    />
                    <div
                      class={`w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] p-6 border-4 group-hover:-translate-y-2 transition-transform duration-300 -skew-x-[2deg] ${
                        isDark
                          ? "border-p5-white bg-p5-black shadow-[6px_6px_0_0_#E50012]"
                          : "border-p5-black bg-p5-white shadow-[6px_6px_0_0_#0F0F0F]"
                      }`}
                    >
                      <div class="flex flex-wrap gap-4 items-center justify-between mb-4 skew-x-[2deg]">
                        <h3
                          class={`font-display text-3xl uppercase leading-none ${
                            isDark ? "text-p5-white" : "text-p5-black"
                          }`}
                        >
                          <span class="lang-es">{item.title.es}</span>
                          <span class="lang-en">{item.title.en}</span>
                        </h3>
                        <span
                          class={`font-mono text-sm px-3 py-1 font-bold ${
                            isDark
                              ? "bg-p5-red text-p5-white"
                              : "bg-p5-black text-p5-white"
                          }`}
                        >
                          {item.year}
                        </span>
                      </div>
                      <p
                        class={`font-body text-base opacity-80 skew-x-[2deg] ${
                          isDark ? "text-p5-white" : "text-p5-black"
                        }`}
                      >
                        <span class="lang-es">{item.description.es}</span>
                        <span class="lang-en">{item.description.en}</span>
                      </p>
                    </div>
                  </div>
                );
              })
            }
          </div>
        </details>
      </div>
    </section>

    <section class="relative">
      <div
        class="absolute -top-6 -right-4 bg-p5-red text-p5-white px-6 py-2 font-display text-3xl -skew-x-[6deg] z-10 border-2 border-p5-black shadow-[4px_4px_0_0_#0F0F0F]"
      >
        <span class="inline-block skew-x-[6deg]">
          <span class="lang-es">04. INTERESES Y HOBBIES</span>
          <span class="lang-en">04. INTERESTS & HOBBIES</span>
        </span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 pt-10">
        {
          hobbyCards.map((card) => (
            <div
              class={`aspect-square flex flex-col items-center justify-center p-6 text-center transform hover:scale-105 transition-all cursor-crosshair group ${
                card.variant === "light"
                  ? "bg-p5-white border-4 border-p5-black hover:rotate-3 shadow-hard"
                  : card.variant === "red"
                  ? "bg-p5-red border-4 border-p5-black hover:rotate-3 shadow-[8px_8px_0_0_#0F0F0F]"
