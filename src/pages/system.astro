---
import Layout from "../layouts/Layout.astro";
import { TechTag } from "../components/p5/TechTag";
import { P5Button } from "../components/p5/P5Button";
import { ProjectCard } from "../components/p5/ProjectCard";
import { FeaturedProject } from "../components/p5/FeaturedProject";
import type { ProjectData } from "../types";
import { CallingCard } from "../components/p5/CallingCard";
import { StatHexagon } from "../components/p5/StatHexagon";
import { TechIconsGrid } from "../components/p5/TechIcons";
import { TestimonialCard } from "../components/p5/TestimonialCard";
import { Image } from "astro:assets";
import profileImage from "../Assets/Images/Foto de perfil.png";
import proyectos from "../data/proyectos.json";

import "../styles/global.css";

const proyectosTyped = proyectos as ProjectData[];
const featuredProjects = proyectosTyped.filter((p) => p.featured);
---

<Layout title="Design System - Portafolio P5">
  <header class="mb-16 border-b-8 border-p5-red pb-8 relative">
    <div
      class="absolute -top-10 -left-10 w-32 h-32 bg-p5-red/20 -skew-x-[12deg] -z-10 blur-xl"
    >
    </div>
    <h1
      class="font-display text-8xl md:text-9xl text-p5-red uppercase tracking-tighter leading-none"
    >
      Design <span class="text-[var(--text-color)]">System</span>
    </h1>
    <p class="font-mono text-xl mt-4 opacity-70">
      Project: Portfolio_Refactor_V1.tsx
    </p>
  </header>

  <div class="space-y-32 pb-40">
    <!-- 1. SISTEMA DE REJILLA (Columnas) -->
    <section class="space-y-12">
      <div class="space-y-4">
        <h2
          class="font-display text-5xl bg-p5-black text-p5-white inline-block px-6 py-2 -skew-x-[6deg] shadow-hard"
        >
          <span class="inline-block skew-x-[6deg]">Layout Structure</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="space-y-4">
          <h3 class="font-display text-3xl text-p5-red uppercase">
            Desktop Grid (12 Units)
          </h3>
          <div
            class="grid grid-cols-12 gap-2 bg-p5-black/20 p-2 border-2 border-adaptive border-dashed"
          >
            {
              Array.from({ length: 12 }).map((_, i) => (
                <div
                  class={`col-span-1 h-8 ${i % 2 === 0 ? "bg-p5-red" : "bg-p5-black border border-white"} opacity-80`}
                />
              ))
            }
          </div>
        </div>
        <div class="space-y-4">
          <h3 class="font-display text-3xl text-p5-red uppercase">
            Android Grid (4 Units)
          </h3>
          <div class="max-w-[280px]">
            <div
              class="grid grid-cols-4 gap-2 bg-p5-black/20 p-2 border-4 border-p5-black shadow-hard"
            >
              {
                Array.from({ length: 4 }).map((_, i) => (
                  <div
                    class={`col-span-1 h-12 ${i % 2 === 0 ? "bg-p5-red" : "bg-p5-black border border-white"}`}
                  />
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. FUNDAMENTOS VISUALES (Tipografía, Colores, Patrones) -->
    <section class="space-y-16">
      <h2
        class="font-display text-5xl bg-p5-red text-p5-white inline-block px-6 py-2 -skew-x-[6deg] shadow-hard-adaptive mb-4"
      >
        <span class="inline-block skew-x-[6deg]">Visual Fundamentals</span>
      </h2>

      <!-- Tipografía -->
      <div
        class="bg-panel border-4 border-adaptive shadow-hard-adaptive skew-x-[3deg]"
      >
        <div class="-skew-x-[3deg] p-8 space-y-8 text-[var(--text-color)]">
          <h3
            class="font-display text-4xl text-p5-red border-b-2 border-p5-red pb-2 mb-6"
          >
            Tipografía
          </h3>
          <div class="border-b-2 border-adaptive/30 pb-6">
            <div
              class="font-display text-[80px] uppercase leading-none tracking-wide mb-2"
            >
              H1 Bebas Neue
            </div>
            <h4 class="font-mono font-bold text-p5-red">
              H1 / 110px / Bebas Neue — Hero, Títulos masivos
            </h4>
          </div>
          <div class="border-b-2 border-adaptive/30 pb-6">
            <div
              class="font-display text-[56px] uppercase leading-none tracking-wide mb-2"
            >
              H2 Bebas Neue 68px
            </div>
            <h4 class="font-mono font-bold text-p5-red">
              H2 / 68px / Bebas Neue — Secciones principales
            </h4>
          </div>
          <div class="border-b-2 border-adaptive/30 pb-6">
            <div
              class="font-display text-[36px] uppercase leading-none tracking-wide mb-2"
            >
              H3 Bebas Neue 42px
            </div>
            <h4 class="font-mono font-bold text-p5-red">
              H3 / 42px / Bebas Neue — Títulos de cards
            </h4>
          </div>
          <div class="border-b-2 border-adaptive/30 pb-6">
            <div class="font-body text-[16px] leading-relaxed mb-2 max-w-2xl">
              Body Inter 16px. Texto de cuerpo estándar para máxima legibilidad
              en descripciones y lectura prolongada.
            </div>
            <h4 class="font-mono font-bold text-p5-red">
              Body / 16px / Inter — Párrafos y descripciones
            </h4>
          </div>
          <div class="pb-2">
            <div class="font-mono text-[14px] leading-relaxed mb-2">
              Mono Roboto Mono 14px. Código y Tags técnicos.
            </div>
            <h4 class="font-mono font-bold text-p5-red">
              Mono / 14px / Roboto Mono — Etiquetas y código
            </h4>
          </div>
        </div>
      </div>

      <!-- Colores -->
      <div class="space-y-8 mt-16">
        <h3
          class="font-display text-4xl text-p5-red border-b-2 border-p5-red pb-2"
        >
          Paleta Primaria (Marca &amp; Contraste)
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8">
          <div class="space-y-2 group">
            <div
              class="w-full h-28 bg-p5-red shadow-hard-adaptive -skew-x-[6deg] border-4 border-p5-black group-hover:-translate-y-1 transition-transform"
            >
            </div>
            <div class="font-display text-2xl pt-2 uppercase">Base Red</div>
            <div class="font-mono text-xs font-bold">#E50012</div>
            <p class="text-xs opacity-80">
              Call To Actions principales, acentos fuertes y decoradores.
            </p>
          </div>
          <div class="space-y-2 group">
            <div
              class="w-full h-28 bg-p5-red-dark shadow-hard-adaptive -skew-x-[6deg] border-4 border-p5-black group-hover:-translate-y-1 transition-transform"
            >
            </div>
            <div class="font-display text-2xl pt-2 uppercase">Dark Red</div>
            <div class="font-mono text-xs font-bold">#990000</div>
            <p class="text-xs opacity-80">
              Estados "Hover" o presionado en botones principales.
            </p>
          </div>
          <div class="space-y-2 group">
            <div
              class="w-full h-28 bg-p5-red-light shadow-hard-adaptive -skew-x-[6deg] border-4 border-p5-black group-hover:-translate-y-1 transition-transform"
            >
            </div>
            <div class="font-display text-2xl pt-2 uppercase">Light Red</div>
            <div class="font-mono text-xs font-bold">#FF3344</div>
            <p class="text-xs opacity-80">
              Highlights visuales o destellos de energía en animaciones.
            </p>
          </div>
          <div class="space-y-2 group">
            <div
              class="w-full h-28 bg-p5-yellow shadow-hard-adaptive -skew-x-[6deg] border-4 border-p5-black group-hover:-translate-y-1 transition-transform"
            >
            </div>
            <div class="font-display text-2xl pt-2 uppercase">Cyber Yellow</div>
            <div class="font-mono text-xs font-bold">#FFD700</div>
            <p class="text-xs opacity-80">
              Alertas, insignias de proyectos destacados ("Elite").
            </p>
          </div>
        </div>

        <h3 class="font-display text-4xl border-b-2 border-adaptive pb-2 mt-12">
          Paleta Secundaria (Estructura &amp; Fondos)
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
          <div class="space-y-2 group">
            <div
              class="w-full h-28 bg-p5-black shadow-hard-adaptive skew-x-[6deg] border-4 border-adaptive group-hover:-translate-y-1 transition-transform"
            >
            </div>
            <div class="font-display text-2xl pt-2 uppercase">Ink Black</div>
            <div class="font-mono text-xs font-bold">#0F0F0F</div>
            <p class="text-xs opacity-80">
              Fondo principal (default), contornos obligatorios de botones
              rojos.
            </p>
          </div>
          <div class="space-y-2 group">
            <div
              class="w-full h-28 bg-p5-white shadow-hard-adaptive -skew-x-[6deg] border-4 border-p5-black group-hover:-translate-y-1 transition-transform"
            >
            </div>
            <div class="font-display text-2xl pt-2 uppercase">Paper White</div>
            <div class="font-mono text-xs font-bold">#F4F4F4</div>
            <p class="text-xs opacity-80">
              Texto sobre fondos negros, o fondo en Light Mode.
            </p>
          </div>
          <div class="space-y-2 group">
            <div
              class="w-full h-28 bg-p5-gray shadow-hard-adaptive skew-x-[6deg] border-4 border-adaptive group-hover:-translate-y-1 transition-transform"
            >
            </div>
            <div class="font-display text-2xl pt-2 uppercase">Shadow Gray</div>
            <div class="font-mono text-xs font-bold">#2C2C2C</div>
            <p class="text-xs opacity-80">
              Cards secundarias, bordes inactivos o ruido de fondo.
            </p>
          </div>
        </div>
      </div>

      <!-- Patrones -->
      <div class="space-y-4 mt-16">
        <h3
          class="font-display text-4xl text-p5-red border-b-2 border-p5-red pb-2"
        >
          Patrones de Fondo
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
          <div
            class="h-32 bg-p5-red relative border-4 border-p5-black overflow-hidden"
          >
            <div
              class="absolute inset-0 opacity-50 mix-blend-multiply"
              style="background-image: radial-gradient(#0F0F0F 2px, transparent 2px); background-size: 8px 8px;"
            >
            </div>
            <span
              class="absolute bottom-2 left-2 bg-p5-black text-p5-white px-2 py-1 font-mono text-xs font-bold -skew-x-[6deg]"
              ><span class="inline-block skew-x-[6deg]">Halftone</span></span
            >
          </div>
          <div
            class="h-32 bg-p5-yellow relative border-4 border-p5-black overflow-hidden"
          >
            <div
              class="absolute inset-0 opacity-30 mix-blend-multiply"
              style="background-image: repeating-linear-gradient(45deg, #0F0F0F 0, #0F0F0F 2px, transparent 2px, transparent 8px);"
            >
            </div>
            <span
              class="absolute bottom-2 left-2 bg-p5-black text-p5-white px-2 py-1 font-mono text-xs font-bold -skew-x-[6deg]"
              ><span class="inline-block skew-x-[6deg]">Stripes</span></span
            >
          </div>
          <div
            class="h-32 bg-p5-black relative border-4 border-p5-white overflow-hidden"
          >
            <div
              class="absolute inset-0 opacity-20"
              style="background-image: radial-gradient(#F4F4F4 1px, transparent 1px); background-size: 16px 16px;"
            >
            </div>
            <span
              class="absolute bottom-2 left-2 bg-p5-white text-p5-black px-2 py-1 font-mono text-xs font-bold -skew-x-[6deg]"
              ><span class="inline-block skew-x-[6deg]">Grid</span></span
            >
          </div>
        </div>
      </div>

      <!-- Iconografía -->
      <div class="space-y-6 mt-16">
        <h3 class="font-display text-4xl text-p5-red border-b-2 border-p5-red pb-2">
          Iconography & Symbols
        </h3>
        <p class="font-body text-base opacity-90 max-w-3xl leading-relaxed">
          En este estilo visual, los íconos rara vez son amigables o redondeados. Deben transmitir urgencia, estilo y agresividad. Se construyen a base de formas geométricas duras (estrellas puntiagudas, flechas masivas, exclamaciones gruesas).
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="bg-panel border-4 border-adaptive p-6 flex flex-col items-center justify-center gap-4 shadow-hard-adaptive group transition-transform hover:-translate-y-2">
            <svg class="w-12 h-12 text-p5-red" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
            <span class="font-mono text-xs tracking-widest font-bold uppercase">Highlight</span>
          </div>
          <div class="bg-panel border-4 border-adaptive p-6 flex flex-col items-center justify-center gap-4 shadow-hard-adaptive group transition-transform hover:-translate-y-2">
            <svg class="w-12 h-12 text-p5-red" fill="currentColor" viewBox="0 0 24 24"><path d="M10 17l5-5-5-5v10z"/><path d="M0 24V0h24v24H0z" fill="none"/></svg>
            <span class="font-mono text-xs tracking-widest font-bold uppercase">Directional</span>
          </div>
          <div class="bg-panel border-4 border-adaptive p-6 flex flex-col items-center justify-center gap-4 shadow-hard-adaptive group transition-transform hover:-translate-y-2">
            <svg class="w-12 h-12 text-p5-red" fill="currentColor" viewBox="0 0 24 24"><path d="M11 15h2v2h-2zm0-8h2v6h-2zm.99-5C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/></svg>
            <span class="font-mono text-xs tracking-widest font-bold uppercase">Alert</span>
          </div>
          <div class="bg-panel border-4 border-adaptive p-6 flex flex-col items-center justify-center gap-4 shadow-hard-adaptive group transition-transform hover:-translate-y-2">
            <svg class="w-12 h-12 text-p5-red" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M12 2v4m0 12v4M2 12h4m12 0h4m-9-5a5 5 0 110 10 5 5 0 010-10z"/></svg>
            <span class="font-mono text-xs tracking-widest font-bold uppercase">Target</span>
          </div>
        </div>
      </div>

      <!-- Tech Stack Icons -->
      <div class="space-y-8 mt-16">
        <div class="flex items-center gap-4 mb-6">
          <h3 class="font-display text-4xl text-p5-red border-b-2 border-p5-red pb-2">
            Tech Stack Icons
          </h3>
          <span class="font-mono text-xs bg-p5-black text-p5-white px-3 py-1 -skew-x-[6deg] opacity-80">
            <span class="inline-block skew-x-[6deg]">svgl Library</span>
          </span>
        </div>
        <p class="font-body text-base opacity-90 max-w-3xl leading-relaxed mb-8">
          Iconos SVG de las tecnologías del stack, importados desde la librería <strong>svgl</strong>. 
          Se renderizan como SVG inline con tratamiento monocromático para integrarse al sistema de diseño P5.
          Al hacer hover, cambian al rojo de marca.
        </p>
        <TechIconsGrid client:load />
      </div>
    </section>

    <!-- 3. COMPONENTES PRIMITIVOS (Botones, Tags y Contenedores) -->
    <section class="space-y-16">
      <h2
        class="font-display text-5xl bg-p5-black text-p5-white inline-block px-6 py-2 -skew-x-[6deg] shadow-hard"
      >
        <span class="inline-block skew-x-[6deg]">Primitive UI Components</span>
      </h2>

      <!-- Reglas de Contenedores -->
      <div
        class="bg-panel border-l-8 border-p5-red p-6 shadow-hard-adaptive mb-12"
      >
        <h3 class="font-display text-3xl mb-2 uppercase">General UI Rules</h3>
        <ul class="font-body text-sm space-y-2 opacity-90 list-disc pl-4">
          <li>
            <strong>Border Radius:</strong> Siempre <code
              class="bg-p5-black text-p5-white px-1">0px</code
            >. Nunca se usan esquinas redondeadas. Todo es afilado.
          </li>
          <li>
            <strong>Angulación (Skew):</strong> Los paneles usan <code
              class="bg-p5-black text-p5-white px-1">skew-x-[3deg]</code
            > o <code class="bg-p5-black text-p5-white px-1"
              >-skew-x-[6deg]</code
            > para romper la verticalidad. El contenido interior siempre debe des-angularse
            con el valor inverso para que el texto sea legible.
          </li>
          <li>
            <strong>Rotación:</strong> Textos superpuestos y "tiritas" usan <code
              class="bg-p5-black text-p5-white px-1">rotate-2</code
            > o <code class="bg-p5-black text-p5-white px-1">-rotate-2</code>.
          </li>
          <li>
            <strong>Sombras:</strong> Uso exclusivo de "Hard Shadows" (sin desenfoque/blur).
            Sombras sólidas desplazadas típicamente en <code
              class="bg-p5-black text-p5-white px-1">6px 6px</code
            > o <code class="bg-p5-black text-p5-white px-1">12px 12px</code>.
          </li>
        </ul>
      </div>

      <!-- Containers / Panels -->
      <div class="space-y-6">
        <h3
          class="font-display text-4xl text-p5-red border-b-2 border-p5-red pb-2"
        >
          Structural Containers
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <!-- Skewed Adaptive Panel -->
          <div class="group flex flex-col">
            <h4
              class="font-mono text-sm text-p5-red mb-2 uppercase tracking-widest"
            >
              Adaptive Skewed Panel
            </h4>
            <div
              class="bg-panel border-4 border-adaptive shadow-hard-adaptive skew-x-[3deg] min-h-[160px] transition-transform hover:-translate-y-1"
            >
              <div
                class="-skew-x-[3deg] p-6 flex items-center justify-center h-full"
              >
                <span class="font-display text-2xl opacity-50"
                  >Content Area</span
                >
              </div>
            </div>
            <p class="font-body text-sm opacity-80 mt-4 leading-relaxed">
              <strong>Uso:</strong> Contenedor base primario para agrupar contenido
              complejo (Sección Hero, Confidant Bars, Tarjetas de Información).<br
              />
              <strong>Config:</strong>
              <code class="text-p5-red text-xs"
                >bg-panel border-4 border-adaptive shadow-hard-adaptive
                skew-x-[3deg]</code
              >. Se adapta automáticamente al modo oscuro/claro.
            </p>
          </div>

          <!-- Hard Black Halftone Panel -->
          <div class="group flex flex-col">
            <h4
              class="font-mono text-sm text-p5-red mb-2 uppercase tracking-widest"
            >
              Hard Black + Halftone
            </h4>
            <div
              class="bg-p5-black border-4 border-p5-white shadow-hard relative overflow-hidden min-h-[160px] transition-transform hover:-translate-y-1"
            >
              <div class="absolute inset-0 bg-halftone opacity-10"></div>
              <div
                class="relative z-10 p-6 flex items-center justify-center h-full"
              >
                <span class="font-display text-2xl text-p5-white opacity-50"
                  >Content Area</span
                >
              </div>
            </div>
            <p class="font-body text-sm opacity-80 mt-4 leading-relaxed">
              <strong>Uso:</strong> Elementos que necesitan destacar agresivamente
              (Tarjetas de Proyecto en grilla, Botoneras). Siempre es negro, sin importar
              el modo.<br />
              <strong>Config:</strong>
              <code class="text-p5-red text-xs"
                >bg-p5-black border-4 border-p5-white shadow-hard</code
              >. Utiliza textura Halftone interna para reducir el peso de un
              bloque negro completamente sólido.
            </p>
          </div>
        </div>
      </div>

      <!-- Text Containers -->
      <div class="space-y-6">
        <h3
          class="font-display text-4xl text-p5-red border-b-2 border-p5-red pb-2"
        >
          Text & Label Containers
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Rotated Title Badge -->
          <div class="space-y-4">
            <h4 class="font-mono text-sm text-p5-red uppercase tracking-widest">
              Rotated Badge
            </h4>
            <div
              class="p-4 bg-panel border-2 border-dashed border-adaptive min-h-[120px] flex items-center justify-center overflow-hidden"
            >
              <div
                class="bg-p5-black -rotate-2 border-p5-red shadow-hard-white text-p5-white p-3 border-4 inline-block"
              >
                <span class="font-display text-2xl tracking-widest uppercase"
                  >SECTION_TITLE</span
                >
              </div>
            </div>
            <p class="font-body text-xs opacity-80 leading-relaxed">
              <strong>Uso:</strong> Títulos superpuestos masivos en tarjetas de proyecto.<br
              />
              <strong>Config:</strong>
              <code class="text-p5-red"
                >-rotate-2 border-4 shadow-hard-white</code
              >. Rompe la grilla intencionalmente y no requiere que el texto se
              des-rote internamente.
            </p>
          </div>

          <!-- Dialogue Box Base -->
          <div class="space-y-4">
            <h4 class="font-mono text-sm text-p5-red uppercase tracking-widest">
              Dialogue Box
            </h4>
            <div
              class="p-4 bg-panel border-2 border-dashed border-adaptive min-h-[120px] flex items-center justify-center"
            >
              <div
                class="bg-p5-black p-4 border-4 border-p5-white -skew-y-[2deg] shadow-[8px_8px_0_0_#E50012] w-full relative"
              >
                <span class="font-display text-xl text-p5-white opacity-50"
                  >Texto de narrativa...</span
                >
              </div>
            </div>
            <p class="font-body text-xs opacity-80 leading-relaxed">
              <strong>Uso:</strong> Narrativa o descripciones de personaje (Calling
              Card).<br />
              <strong>Config:</strong>
              <code class="text-p5-red"
                >-skew-y-[2deg] shadow-[X_Y_0_0_#E50012]</code
              >. Se inclina ligeramente en Y (arriba/abajo), no en X.
            </p>
          </div>

          <!-- Cutout Text -->
          <div class="space-y-4">
            <h4 class="font-mono text-sm text-p5-red uppercase tracking-widest">
              Cutout Highlights
            </h4>
            <div
              class="p-4 bg-panel border-2 border-dashed border-adaptive min-h-[120px] flex items-center justify-center flex-col gap-2"
            >
              <span
                class="cutout-white font-display text-2xl tracking-widest uppercase"
                >HIGHLIGHT</span
              >
              <span
                class="cutout-black font-display text-2xl tracking-widest uppercase text-p5-white"
                >HIGHLIGHT</span
              >
            </div>
