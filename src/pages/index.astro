---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/p5/NavBar.astro";
import { TechTag } from "../components/p5/TechTag";
import {
  FeaturedProject,
  type MediaItem,
} from "../components/p5/FeaturedProject";
import { ConfidantBar } from "../components/p5/ConfidantBar";
import { Image } from "astro:assets";
import profileImage from "../Assets/Images/Foto de perfil.png";

import "../styles/global.css";

// Mock Data for Projects
const phantomStrideMedia: MediaItem[] = [
  {
    type: "video",
    url: "/src/Assets/Proyectos/Referencia/2026-04-24 09-56-40.mkv",
    filename: "DEMO_VIDEO.MKV",
  },
  {
    type: "image",
    url: "/src/Assets/Proyectos/Referencia/Captura de pantalla 2026-05-08 194130.png",
    filename: "SCREENSHOT_01.PNG",
  },
];

const cyberCoreMedia: MediaItem[] = [
  {
    type: "image",
    url: "/src/Assets/Proyectos/Referencia/Captura de pantalla 2026-05-08 194455.png",
    filename: "MODEL_RENDER_01.PNG",
  },
];
---

<Layout title="Portafolio - Alejandro Sandoval">
  <!-- Navigation Bar -->
  <NavBar currentPath="/" />

  <div class="space-y-32 pb-40 px-2 md:px-6 w-full max-w-none mx-auto">
    <!-- SECCIÓN HERO / PERFIL -->
    <section id="sobre-mi" class="space-y-8 relative mt-16">
      <div class="border-4 border-adaptive bg-panel shadow-hard-adaptive skew-x-[3deg]">
        <div class="-skew-x-[3deg] p-8 lg:p-12 xl:p-16 flex flex-col lg:flex-row gap-16 xl:gap-32 items-center justify-between">
          <!-- Avatar -->
          <div class="flex flex-col items-center gap-6 shrink-0 mx-auto md:mx-0">
            <div class="relative group cursor-pointer w-64 h-64 md:w-80 md:h-80">
              <div class="absolute inset-0 bg-p5-red -skew-x-[6deg] translate-x-4 translate-y-4 group-hover:translate-x-6 group-hover:translate-y-6 transition-transform duration-300 border-4 border-p5-black"></div>
              <div class="absolute inset-0 border-4 border-p5-black -skew-x-[6deg] overflow-hidden bg-p5-white z-10">
                <div class="skew-x-[6deg] w-[120%] h-full -ml-[10%] relative scale-110 group-hover:scale-100 transition-transform duration-500">
                  <Image src={profileImage} alt="Alejandro Sandoval" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" />
                  <div class="absolute inset-0 opacity-20 pointer-events-none mix-blend-multiply" style="background-image: radial-gradient(#0F0F0F 2px, transparent 2px); background-size: 8px 8px;"></div>
                </div>
              </div>
              <div class="absolute -bottom-6 -left-6 bg-p5-yellow px-4 py-1 border-4 border-p5-black -rotate-6 shadow-hard z-20 group-hover:-rotate-3 group-hover:scale-110 transition-transform duration-300">
                <span class="font-display text-2xl text-p5-black uppercase tracking-widest leading-none">LVL 23</span>
              </div>
            </div>
            <div class="font-mono text-xs text-[var(--text-color)] opacity-80 bg-panel border-2 border-adaptive px-4 py-2 -skew-x-[6deg] shadow-sm mt-4 text-center">
              <span class="inline-block skew-x-[6deg]">
                &gt; STATUS: <span class="text-p5-red font-bold tracking-widest animate-pulse">OPEN TO WORK</span>
              </span>
            </div>
          </div>

          <!-- Texto Hero -->
          <div class="flex-1 space-y-6">
            <h3 class="font-display text-5xl md:text-7xl uppercase leading-none text-[var(--text-color)] flex flex-wrap items-center gap-3">
              Alejandro
              <span class="text-p5-red inline-block -skew-x-[6deg] border-4 border-p5-black px-3 pb-1 bg-p5-black shadow-[4px_4px_0_0_#E50012]">
                <span class="inline-block skew-x-[6deg]">Sandoval</span>
              </span>
            </h3>
            <p class="font-body text-[var(--text-color)] opacity-90 text-lg border-l-4 border-p5-red pl-4 leading-relaxed">
              Desarrollador de videojuegos y experiencias interactivas. Especializado en Unity y Game Desing Quiero contar historias através de mecánicas, personajes y aventuras inolvidables.
            </p>

            <div class="pt-4">
              <h4 class="font-display text-2xl mb-4 text-[var(--text-color)] uppercase">Tech Stack</h4>
              <div class="flex flex-wrap gap-3 items-center">
                <span class="bg-p5-black text-p5-white font-mono text-sm px-3 py-1 -skew-x-[6deg] -rotate-2 hover:rotate-0 hover:bg-p5-red transition-all cursor-default border-2 border-p5-white group"><span class="inline-block skew-x-[6deg]">Unity</span></span>
                <span class="bg-p5-black text-p5-white font-mono text-sm px-3 py-1 skew-x-[6deg] rotate-1 hover:rotate-0 hover:bg-p5-red transition-all cursor-default border-2 border-p5-white group"><span class="inline-block -skew-x-[6deg]">C#</span></span>
                <span class="bg-p5-black text-p5-white font-mono text-sm px-3 py-1 -skew-x-[6deg] -rotate-1 hover:rotate-0 hover:bg-p5-red transition-all cursor-default border-2 border-p5-white group"><span class="inline-block skew-x-[6deg]">Python</span></span>
                <span class="bg-p5-black text-p5-white font-mono text-sm px-3 py-1 skew-x-[6deg] rotate-2 hover:rotate-0 hover:bg-p5-red transition-all cursor-default border-2 border-p5-white group"><span class="inline-block -skew-x-[6deg]">Java</span></span>
                <span class="bg-p5-black text-p5-white font-mono text-sm px-3 py-1 -skew-x-[6deg] -rotate-2 hover:rotate-0 hover:bg-p5-red transition-all cursor-default border-2 border-p5-white group"><span class="inline-block skew-x-[6deg]">JS / HTML5 / CSS</span></span>
                <span class="bg-p5-black text-p5-white font-mono text-sm px-3 py-1 skew-x-[6deg] rotate-1 hover:rotate-0 hover:bg-p5-red transition-all cursor-default border-2 border-p5-white group"><span class="inline-block -skew-x-[6deg]">React</span></span>
                <span class="bg-p5-black text-p5-white font-mono text-sm px-3 py-1 -skew-x-[6deg] rotate-1 hover:rotate-0 hover:bg-p5-red transition-all cursor-default border-2 border-p5-white group"><span class="inline-block skew-x-[6deg]">Astro</span></span>
                <span class="bg-p5-black text-p5-white font-mono text-sm px-3 py-1 skew-x-[6deg] -rotate-2 hover:rotate-0 hover:bg-p5-red transition-all cursor-default border-2 border-p5-white group"><span class="inline-block -skew-x-[6deg]">Blender</span></span>
                <span class="bg-p5-black text-p5-white font-mono text-sm px-3 py-1 -skew-x-[6deg] -rotate-1 hover:rotate-0 hover:bg-p5-red transition-all cursor-default border-2 border-p5-white group"><span class="inline-block skew-x-[6deg]">Figma</span></span>
                <span class="bg-p5-black text-p5-white font-mono text-sm px-3 py-1 skew-x-[6deg] rotate-1 hover:rotate-0 hover:bg-p5-red transition-all cursor-default border-2 border-p5-white group"><span class="inline-block -skew-x-[6deg]">Substance</span></span>
                <span class="bg-p5-black text-p5-white font-mono text-sm px-3 py-1 -skew-x-[6deg] -rotate-2 hover:rotate-0 hover:bg-p5-red transition-all cursor-default border-2 border-p5-white group"><span class="inline-block skew-x-[6deg]">Git / GitHub</span></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Barras de Confidente -->
    <section class="space-y-8">
      <h3 class="font-display text-4xl text-p5-red border-b-2 border-p5-red pb-2 inline-block -skew-x-[6deg]">
        <span class="inline-block skew-x-[6deg]">Confidant Skills</span>
      </h3>
      <div class="bg-panel border-4 border-adaptive shadow-hard-adaptive skew-x-[3deg]">
        <div class="-skew-x-[3deg] p-8 lg:p-12 grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-8">
          <ConfidantBar 
            client:load
            title="UNITY ENGINE" 
            rank={8} 
            percentage={80} 
            description="Experiencia avanzada desarrollando sistemas complejos, shaders en URP/HDRP, y arquitecturas modulares para juegos 2D y 3D." 
          />
          <ConfidantBar 
            client:load
            title="ASTRO / REACT" 
            rank={5} 
            percentage={50} 
            description="Creación de interfaces web modernas y estáticas, integrando frameworks y componentes reutilizables con un enfoque en el rendimiento." 
          />
          <ConfidantBar 
            client:load
            title="C# / PYTHON / JAVA" 
            rank={7} 
            percentage={70} 
            description="Sólidos fundamentos en programación orientada a objetos, scripting, automatización de tareas y desarrollo de backend." 
          />
          <ConfidantBar 
            client:load
            title="MAYA / MUDBOX" 
            rank={6} 
            percentage={60} 
            description="Modelado 3D, retopología y texturizado para assets integrados en motores de videojuegos." 
          />
          <ConfidantBar 
            client:load
            title="UI / UX / FIGMA" 
            rank={6} 
            percentage={60} 
            description="Diseño de wireframes, prototipos interactivos y sistemas de diseño enfocados en la experiencia de usuario final." 
          />
        </div>
      </div>
    </section>

    <!-- PROYECTOS DESTACADOS -->
    <section id="proyectos" class="flex flex-col gap-12 mt-16">
      <h2 class="font-display text-5xl md:text-6xl bg-p5-black text-p5-white inline-block px-8 py-3 -skew-x-[6deg] shadow-hard self-start mb-8">
        <span class="inline-block skew-x-[6deg]">Featured Projects</span>
      </h2>

      <!-- Project 1 -->
      <FeaturedProject
        client:load
        title="PLANTAGOCHI"
        context="Game Development"
        description="Juego sobre cuidar plantas interactivas. Se desarrollaron diversas mecánicas de crecimiento en Unity."
        tags={["Unity URP", "C# ASYNC"]}
        media={phantomStrideMedia}
        orientation="left"
        primaryButton={{ text: "WATCH DEMO", href: "#" }}
        secondaryButton={{ text: "SOURCE CODE", href: "#" }}
      />

      <!-- Project 2 -->
      <FeaturedProject
        client:load
        title="SVELIATY"
        context="Academic Project"
        description="Proyecto académico de combate RPG. Incluye una fórmula de escalado logístico y generador de personajes voxel modulares."
        tags={["Blender", "Substance", "C#"]}
        media={cyberCoreMedia}
        orientation="right"
        secondaryButton={{ text: "DOWNLOAD EXE", href: "#" }}
      />
      
      <!-- Project 3 -->
      <FeaturedProject
        client:load
        title="RESONADOR VR"
        context="Virtual Reality"
        description="Simulador de exploración de la sala de un Resonador Magnético. Experiencia inmersiva que educa sobre procedimientos médicos de una forma interactiva."
        tags={["Unity", "VR", "Oculus"]}
        media={phantomStrideMedia}
        orientation="left"
        primaryButton={{ text: "DOWNLOAD VR", href: "#" }}
        secondaryButton={{ text: "SOURCE CODE", href: "#" }}
      />

      <div class="flex justify-center mt-12">
        <a href="/proyectos" class="font-display text-4xl bg-p5-red text-p5-white px-12 py-6 -skew-x-[6deg] shadow-[8px_8px_0_0_#0F0F0F] hover:-translate-y-2 hover:shadow-[12px_12px_0_0_#0F0F0F] transition-all flex items-center gap-4 group">
          <span class="inline-block skew-x-[6deg]">VIEW ALL PROJECTS</span>
          <svg class="w-8 h-8 skew-x-[6deg] group-hover:translate-x-2 transition-transform" fill="currentColor" viewBox="0 0 20 20"><path d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z"/></svg>
        </a>
      </div>
    </section>
  </div>
</Layout>
